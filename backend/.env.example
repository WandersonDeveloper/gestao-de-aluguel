DATABASE_URL=postgresql+psycopg2://alugueis:alugueis@db:5432/alugueis
JWT_SECRET_KEY=change-me
JWT_ALGORITHM=HS256
JWT_EXPIRES_MINUTES=60
S3_ENDPOINT_URL=http://minio:9000
S3_PUBLIC_ENDPOINT_URL=http://localhost:9000
S3_ACCESS_KEY=alugueis
S3_SECRET_KEY=alugueis123
S3_BUCKET_NAME=equipment-photos

# Dados do locador/prestador exibidos no PDF de contrato gerado (ver
# regras-de-negocio.md) — sem valor padrão de produção, personalize aqui.
COMPANY_NAME=Sua Empresa de Locação Ltda.
COMPANY_DOCUMENT=00.000.000/0001-00
COMPANY_ADDRESS=Endereço completo da sede

# Integração com WhatsApp via Evolution API (ver regras-de-negocio.md e
# README para o passo a passo de configuração da instância/QR code).
EVOLUTION_API_URL=http://evolution-api:8080
EVOLUTION_API_KEY=change-me
EVOLUTION_INSTANCE_NAME=gestao-alugueis

# Credenciais da API oficial do WhatsApp (Cloud API da Meta) — deixe em branco
# para usar o modo padrão (QR code, Baileys). Preencha os três quando tiver a
# conta comercial aprovada pela Meta: a Evolution API passa a falar com a
# Cloud API por baixo dos panos, sem precisar de QR code (ver regras-de-negocio.md).
META_WHATSAPP_TOKEN=
META_WHATSAPP_NUMBER_ID=
META_WHATSAPP_BUSINESS_ID=

# Webhook de confirmação de assinatura de contrato (ver regras-de-negocio.md).
# BACKEND_INTERNAL_URL é o hostname que a Evolution API usa pra chamar de
# volta o backend, dentro da rede Docker — não precisa expor pra internet.
# Troque WHATSAPP_WEBHOOK_SECRET por um valor aleatório em produção.
BACKEND_INTERNAL_URL=http://backend:8000
WHATSAPP_WEBHOOK_SECRET=change-me
